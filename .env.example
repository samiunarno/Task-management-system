# GEMINI_API_KEY: Required for legacy Gemini components.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# MONGODB_URI: Connection string for your MongoDB database.
MONGODB_URI="mongodb+srv://user:pass@cluster.mongodb.net/studyflow"

# ZHIPU_AI_API_KEY: API key for Zhipu AI (GLM) study assistant.
ZHIPU_AI_API_KEY="MY_ZHIPU_AI_KEY"

# APP_URL: Injected at runtime.
APP_URL="MY_APP_URL"
